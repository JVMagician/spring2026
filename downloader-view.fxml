<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="357.0" prefWidth="407.0" spacing="20.0" style="-fx-background-color: skyblue;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.debugging.pgccdownloaderapp.DownloaderController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="PGCC Download Master" textFill="#7110e6">
      <font>
         <Font name="System Bold" size="18.0" />
      </font></Label>
   <StackPane prefHeight="33.0" prefWidth="367.0">
      <children>
          <ProgressBar fx:id="progress1" maxWidth="1.7976931348623157E308" prefWidth="300.0" />
         <Label fx:id="labelPercent1" text="0%" />
      </children>
   </StackPane>

    <Button fx:id="btn1" onAction="#startDownload1" style="-fx-background-color: cyan;" text="Download PDF">
      <font>
         <Font size="15.0" />
      </font></Button>
   <StackPane prefHeight="13.0" prefWidth="367.0">
      <children>
          <ProgressBar fx:id="progress2" maxWidth="1.7976931348623157E308" prefWidth="300.0" />
         <Label fx:id="labelPercent2" text="0%" />
      </children>
   </StackPane>

    <Button fx:id="btn2" onAction="#startDownload2" style="-fx-background-color: lightgreen;" text="Download MP3">
      <font>
         <Font size="15.0" />
      </font></Button>
   <StackPane layoutX="30.0" layoutY="167.0" prefHeight="11.0" prefWidth="367.0">
      <children>
          <ProgressBar fx:id="progress3" maxWidth="1.7976931348623157E308" prefWidth="300" />
         <Label fx:id="labelPercent3" text="0%" />
      </children>
   </StackPane>

    <Button fx:id="btn3" onAction="#startDownload3" style="-fx-background-color: lightyellow;" text="Download PPT">
      <font>
         <Font size="15.0" />
      </font></Button>
</VBox>
